; & {
    $ErrorActionPreference = "Stop"

    $NomNomDir = "D:\Applications\NOMNOM"
    $ManifestDir = Join-Path $NomNomDir "modManifests"
    $ManifestPath = Join-Path $ManifestDir "ChicanePusherLab.json"

    New-Item -ItemType Directory -Force -Path $ManifestDir | Out-Null

    $Manifest = [ordered]@{
        name = "ChicanePusherLab"
        displayName = "Chicane Pusher Lab"
        description = "Experimental Chicane pusher-prop transplant with native controls, power-budgeted thrust, tuned visuals, blade-angle prop behavior, and cockpit HUD/MFD integration."
        author = "rendresen"
        version = "0.6.57"
        gameVersion = ""
        category = "Aircraft"
        tags = @(
            "Chicane",
            "AttackHelo1",
            "Pusher Prop",
            "Flight Model",
            "Experimental"
        )
        repo = "https://github.com/rendresen/ChicanePusherLab"
        downloadUrl = "https://github.com/rendresen/ChicanePusherLab/releases/download/v0.6.57/ChicanePusherLab-0.6.57.zip"
        installFolder = "BepInEx/plugins/ChicanePusherLab"
        dll = "ChicanePusherLab.dll"
        dependencies = @(
            "BepInEx"
        )
    }

    $Json = $Manifest | ConvertTo-Json -Depth 8
    Set-Content -LiteralPath $ManifestPath -Value $Json -Encoding UTF8

    Write-Host "Wrote manifest:"
    Write-Host $ManifestPath
    Get-Content -LiteralPath $ManifestPath
}
